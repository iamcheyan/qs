# Basic Variables
set $mod Mod1
set $terminal i3-sensible-terminal
font pango:Ubuntu 10

# bindsym Ctrl+Tab exec swayr next-window
# bindsym Ctrl+Shift+Tab exec swayr prev-window

# Input Configuration
# 通用键盘布局
input type:keyboard {
    xkb_layout jp
}

# Autostart
# --- 环境变量同步 (非常重要) ---
# 确保在启动任何 GUI 代理前，DBus 知道这是 Wayland 会话
exec sh -c 'command -v dbus-update-activation-environment >/dev/null && dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway:GNOME XDG_SESSION_TYPE=wayland XAUTHORITY 2>/dev/null || true'
exec sh -c 'command -v systemctl >/dev/null && systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE XAUTHORITY 2>/dev/null || true'

# 允许本地 root 用户访问 XWayland (修复 mintsysadm/pkexec 无法打开 GUI 的问题)
exec_always sh -c 'grep -qi microsoft /proc/version 2>/dev/null && exit 0; [ -n "$DISPLAY" ] && command -v xhost >/dev/null && xhost +si:localuser:root 2>/dev/null || true'

# exec lxqt-panel
exec_always --no-startup-id sh -c 'pkill waybar 2>/dev/null || true; exec waybar -c "$HOME/.config/waybar/sway-wsl/config.jsonc" -s "$HOME/.config/waybar/style.css"'
# exec_always --no-startup-id swaybg -i "$HOME/.config/TWM/background.png" -m fill
exec --no-startup-id sh -c 'command -v fcitx5 >/dev/null || exit 0; grep -qi microsoft /proc/version 2>/dev/null && exit 0; fcitx5 -d'
exec_always --no-startup-id sh -c 'command -v mako >/dev/null || exit 0; grep -qi microsoft /proc/version 2>/dev/null && exit 0; mako'
exec --no-startup-id command -v cliphist >/dev/null && wl-paste --type text --watch cliphist store
exec --no-startup-id command -v cliphist >/dev/null && wl-paste --type image --watch cliphist store
# exec_always --no-startup-id sh -c "pkill -f workspaces.py; $HOME/.config/sway/scripts/workspaces.py"

# Appearance
gaps inner 0
gaps outer 0
default_border pixel 2
smart_borders on

client.focused          #00ff00 #00ff00 #2e3440 #00ff00 #00ff00
client.unfocused        #3b4252 #3b4252 #d8dee9 #3b4252 #3b4252
client.focused_inactive #3b4252 #3b4252 #d8dee9 #3b4252 #3b4252
client.urgent           #bf616a #bf616a #ffffff #bf616a #bf616a

# Workspace Definition
set $ws1 1
set $ws2 2
set $ws3 3
set $ws4 4
set $ws5 5
set $ws6 6
set $ws7 7
set $ws8 8
set $ws9 9
set $ws10 10


bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# 快速拨动窗口到工作区 (Zellij Style, 支持自动创建)
bindsym $mod+Control+l exec $HOME/.config/sway/scripts/move_ws.sh next
bindsym $mod+Control+h exec $HOME/.config/sway/scripts/move_ws.sh prev

# Applications
bindsym $mod+Return exec sh -c 'command -v kitty >/dev/null && kitty || i3-sensible-terminal'

# Window Management
bindsym $mod+Shift+c reload
bindsym $mod+x kill                         # 替换 $mod+q
bindsym $mod+f floating toggle              # 切换 浮动 / 平铺
bindsym $mod+g layout toggle tabbed split   # 切换 标签 / 平铺
# Window Search (Zellij Search Style)
bindsym $mod+s exec swaymsg -t get_tree | jq -r '.. | select(.type? == "con" and .name? != null and .shell? != null) | .name' | wofi --show dmenu -p "Search Windows" | xargs -I{} swaymsg [title="{}"] focus
bindsym $mod+Escape mode "default"          # 强制退出特殊模式

# Ctrl+Tab：当前工作区窗口切换，避免 Windows 抢 Alt+Tab
bindsym Control+Tab focus next
bindsym Control+Shift+Tab focus prev


# Alt+[ / Alt+]：工作区切换，避免 Windows 抢 Win+Tab
bindsym $mod+bracketright workspace next
bindsym $mod+bracketleft workspace prev

# 调整大小
bindsym $mod+Shift+l resize grow width 100 px
bindsym $mod+Shift+h resize shrink width 100 px

#bindsym $mod+Shift+k resize shrink height 100 px
#bindsym $mod+Shift+l resize grow height 100 px

# 应用启动
bindsym $mod+d exec wofi --show drun
bindsym $mod+v exec cliphist list | wofi --dmenu | cliphist decode | wl-copy && wtype -M ctrl v
bindsym $mod+Shift+Escape exec swaynag \
  -t warning \
  -m "Are you sure you want to exit Sway?" \
  -b "Exit" "swaymsg exit" \
  -b "Cancel" ""

# System Power Menu (Visual)
bindsym $mod+Control+BackSpace exec swaynag \
  -t warning \
  -m "Power Management: Choose an action" \
  -b "Hibernate" "systemctl hibernate" \
  -b "Suspend" "systemctl suspend" \
  -b "Reboot" "systemctl reboot" \
  -b "Shutdown" "systemctl poweroff" \
  -b "Exit Sway" "swaymsg exit"

# Window Rules
for_window [app_id="(?i)keepassxc"] floating enable
for_window [class="(?i)keepassxc"] floating enable
for_window [title="(?i)KeePassXC"] floating enable
for_window [window_role="pop-up"] floating enable
for_window [window_role="task_dialog"] floating enable
for_window [window_type="dialog"] floating enable
for_window [window_type="menu"] floating enable
for_window [app_id="org.keepassxc.KeePassXC"] floating enable
for_window [app_id="keepassxc"] floating enable
for_window [class="KeePassXC"] floating enable
for_window [class="keepassxc"] floating enable
for_window [title="Unlock Database - KeePassXC"] floating enable
for_window [title="KeePassXC - Browser Access Request"] floating enable

# Bindings - Screenshot
bindsym Print exec bash -c 'grim - | wl-copy && notify-send "Screenshot" "Full screen copied to clipboard" -t 2000'
bindsym Alt+Print exec bash -c 'filename=~/Downloads/screenshot-$(date +%Y%m%d-%H%M%S).png && grim "$filename" && notify-send "Screenshot" "Saved to Downloads" -t 3000'
bindsym Shift+Print exec bash -c 'filename=~/Downloads/screenshot-$(date +%Y%m%d-%H%M%S).png && grim -g "$(slurp)" "$filename" && notify-send "Area Screenshot" "Saved to Downloads" -t 3000'
bindsym Alt+a exec bash -c 'grim -g "$(slurp)" - | wl-copy && notify-send "Area Screenshot" "Copied to clipboard" -t 2000'

#############################################################
# Modes

# Move mode (Zellij Style)
bindsym $mod+h mode "[ MOVE ] h/j/k/l: Switch Location  ENTER: When done"
mode "[ MOVE ] h/j/k/l: Switch Location  ENTER: When done" {
    bindsym h move left
    bindsym l move right
    bindsym k move up
    bindsym j move down

    bindsym Left  move left
    bindsym Right move right
    bindsym Up    move up
    bindsym Down  move down

    # 退出模式
    bindsym Escape mode "default"
    bindsym Return mode "default"
}

# Move output mode
bindsym $mod+Shift+m mode "[ OUTPUT ] h/j/k/l:screen"
mode "[ OUTPUT ] h/j/k/l:screen" {
    bindsym h move container to output left
    bindsym l move container to output right
    bindsym k move container to output up
    bindsym j move container to output down

    bindsym Left  container to output left
    bindsym Right container to output right
    bindsym Up    container to output up
    bindsym Down  container to output down

    bindsym Escape mode "default"
    bindsym Return mode "default"
}

# Resize mode (Zellij Style)
bindsym $mod+n mode "[ RESIZE ] h/j/k/l: Resize  +/-: Large Resize"
mode "[ RESIZE ] h/j/k/l: Resize  +/-: Large Resize" {
    # 基础调整
    bindsym h resize shrink width 20 px
    bindsym l resize grow width 20 px
    bindsym k resize shrink height 20 px
    bindsym j resize grow height 20 px

    # 大步长调整 (对应 Zellij 的 +/-)
    bindsym plus  resize grow width 50 px; resize grow height 50 px
    bindsym minus resize shrink width 50 px; resize shrink height 50 px
    bindsym Equal resize grow width 50 px; resize grow height 50 px
    bindsym underscore resize shrink width 50 px; resize shrink height 50 px

    # 退出模式
    bindsym Escape mode "default"
    bindsym Return mode "default"
}

# Workspace mode
bindsym $mod+z mode "[ WORKSPACE ] q-p:goto h/l:move_ws Shift:move"
mode "[ WORKSPACE ] q-p:goto h/l:move_ws Shift:move" {
    # 移动窗口并跟随到 上一个/下一个 编号的工作区 (支持自动创建)
    bindsym l exec $HOME/.config/sway/scripts/move_ws.sh next
    bindsym h exec $HOME/.config/sway/scripts/move_ws.sh prev

    # 切换 workspace
    bindsym q workspace number $ws1
    bindsym w workspace number $ws2
    bindsym e workspace number $ws3
    bindsym r workspace number $ws4
    bindsym t workspace number $ws5
    bindsym y workspace number $ws6
    bindsym u workspace number $ws7
    bindsym i workspace number $ws8
    bindsym o workspace number $ws9
    bindsym p workspace number $ws10

    # 移动窗口到 workspace
    bindsym Shift+q move container to workspace number $ws1
    bindsym Shift+w move container to workspace number $ws2
    bindsym Shift+e move container to workspace number $ws3
    bindsym Shift+r move container to workspace number $ws4
    bindsym Shift+t move container to workspace number $ws5
    bindsym Shift+y move container to workspace number $ws6
    bindsym Shift+u move container to workspace number $ws7
    bindsym Shift+i move container to workspace number $ws8
    bindsym Shift+o move container to workspace number $ws9
    bindsym Shift+p move container to workspace number $ws10

    bindsym n workspace prev
    bindsym m workspace next

    # 退出 workspace 模式
    bindsym Escape mode "default"
    bindsym Return mode "default"
}
