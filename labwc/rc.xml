<?xml version="1.0" encoding="UTF-8"?>

<labwc_config>

  <core>
    <gap>0</gap>
  </core>

  <theme>
    <name>BL-Lithium-dark</name>
    <cornerRadius>0</cornerRadius>
    <maximizedDecoration>none</maximizedDecoration>
    <!-- <font name="MesloLGS NF" size="12" /> -->
	
    <font place="ActiveWindow" name="MesloLGS NF" size="9" />
    <font place="InactiveWindow" name="MesloLGS NF" size="9" />
    <font place="MenuHeader" name="MesloLGS NF" size="9" />
    <font place="MenuItem" name="MesloLGS NF" size="9" />

    <font place="OnScreenDisplay">
      <name>MesloLGS NF</name>
      <size>11</size>
      <weight>normal</weight>
    </font>
  </theme>

  <desktops number="4">
    <popupTime>800</popupTime>
  </desktops>

  <windowSwitcher>
    <osd show="yes" style="thumbnail" preview="yes" outlines="yes" />
    <fields>
      <field content="icon" width="15%" />
      <field content="title" width="85%" />
    </fields>
  </windowSwitcher>

  <keyboard>
    <default />

    <!-- 基础启动 -->
    <keybind key="A-Return">
      <action name="Execute" command="alacritty" />
    </keybind>

    <keybind key="A-d">
      <action name="Execute" command="wofi --conf /home/tetsuya/.config/wofi/config-launcher --show drun --allow-images" />
    </keybind>

    <keybind key="A-space">
      <action name="ShowMenu" menu="root-menu" />
    </keybind>

    <keybind key="A-k">
      <action name="ShowMenu" menu="keyboard-menu" />
    </keybind>

    <keybind key="A-S-k">
      <action name="Execute" command="/home/tetsuya/.config/labwc/scripts/keyboard-profile next" />
    </keybind>

    <keybind key="A-q">
      <action name="Close" />
    </keybind>

    <keybind key="A-f">
      <action name="ToggleFullscreen" />
    </keybind>

    <keybind key="A-m">
      <action name="ToggleMaximize" />
    </keybind>

    <!-- 窗口切换 -->
	<keybind key="C-Tab">
		<action name="NextWindow" />
	</keybind>

	<keybind key="C-S-Tab">
		<action name="PreviousWindow" />
	</keybind>
    <!-- <keybind key="C-Tab"> -->
    <!--   <action name="Execute" command="~/.config/labwc/window-switcher forward" /> -->
    <!-- </keybind> -->
    <!---->
    <!-- <keybind key="C-S-Tab"> -->
    <!--   <action name="Execute" command="~/.config/labwc/window-switcher back" /> -->
    <!-- </keybind> -->

    <!-- 工作区切换 -->
    <keybind key="A-Left">
      <action name="GoToDesktop" to="left" wrap="yes" />
    </keybind>

    <keybind key="A-Right">
      <action name="GoToDesktop" to="right" wrap="yes" />
    </keybind>

    <keybind key="A-1">
      <action name="GoToDesktop" to="1" />
    </keybind>
    <keybind key="A-2">
      <action name="GoToDesktop" to="2" />
    </keybind>
    <keybind key="A-3">
      <action name="GoToDesktop" to="3" />
    </keybind>
    <keybind key="A-4">
      <action name="GoToDesktop" to="4" />
    </keybind>

    <keybind key="A-S-1">
      <action name="SendToDesktop" to="1" follow="yes" />
    </keybind>
    <keybind key="A-S-2">
      <action name="SendToDesktop" to="2" follow="yes" />
    </keybind>
    <keybind key="A-S-3">
      <action name="SendToDesktop" to="3" follow="yes" />
    </keybind>
    <keybind key="A-S-4">
      <action name="SendToDesktop" to="4" follow="yes" />
    </keybind>

    <!-- 截图 -->
    <keybind key="Print">
      <action name="Execute" command="~/.config/labwc/screenshot full" />
    </keybind>

    <keybind key="A-Print">
      <action name="Execute" command="~/.config/labwc/screenshot full-save" />
    </keybind>

    <keybind key="S-Print">
      <action name="Execute" command="~/.config/labwc/screenshot area-save" />
    </keybind>

    <keybind key="A-a">
      <action name="Execute" command="~/.config/labwc/screenshot area" />
    </keybind>

    <!-- 亮度 -->
    <keybind key="XF86MonBrightnessUp">
      <action name="Execute" command="~/.config/labwc/brightness-control up" />
    </keybind>

    <keybind key="XF86MonBrightnessDown">
      <action name="Execute" command="~/.config/labwc/brightness-control down" />
    </keybind>

    <!-- 剪贴板 -->
    <keybind key="A-v">
      <action name="Execute" command="$HOME/.config/cliphist/cliphist-wofi" />
    </keybind>

  </keyboard>

  <mouse>
    <default />
    <context name="Frame">
      <mousebind button="A-Left" action="Drag">
        <action name="Move" />
      </mousebind>
    </context>
    <context name="Root">
      <mousebind button="Right" action="Press">
        <action name="ShowMenu" menu="root-menu" />
      </mousebind>
    </context>
  </mouse>

  <windowRules>
    <windowRule identifier="wofi" skipTaskbar="yes" skipWindowSwitcher="yes">
      <action name="ToggleAlwaysOnTop" />
      <action name="Raise" />
      <action name="Focus" />
    </windowRule>
  </windowRules>

</labwc_config>
