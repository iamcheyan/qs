<?xml version="1.0" encoding="UTF-8"?>

<labwc_config>

  <core>
    <gap>3</gap>
  </core>

  <theme>
    <name>BL-Lithium-dark</name>
    <cornerRadius>0</cornerRadius>
    <maximizedDecoration>none</maximizedDecoration>

    <font place="ActiveWindow" name="MesloLGS NF" size="9" />
    <font place="InactiveWindow" name="MesloLGS NF" size="9" />
    <font place="MenuHeader" name="MesloLGS NF" size="9" />
    <font place="MenuItem" name="MesloLGS NF" size="9" />

    <font place="OnScreenDisplay">
      <name>MesloLGS NF</name>
      <size>11</size>
      <weight>normal</weight>
    </font>
  </theme>

  <desktops number="4">
    <popupTime>800</popupTime>
  </desktops>

  <windowSwitcher>
    <osd show="yes" style="thumbnail" preview="yes" outlines="yes" output="cursor" />
    <fields>
      <field content="icon" width="15%" />
      <field content="title" width="85%" />
    </fields>
  </windowSwitcher>

  <keyboard>
    <!-- ⚠️ 此文件由 keybind-profile 脚本自动生成，请勿直接编辑！ -->
    <!-- 修改快捷键请编辑: ~/.config/labwc/keybinds/ 下的 xml 文件 -->
    <default />
    <!-- Mac JIS: macOS 风格快捷键 -->

    <!-- 系统启动 -->
    <keybind key="W-Return">
      <action name="Execute" command="alacritty" />
    </keybind>
    <keybind key="W-d">
      <action name="Execute" command="~/.config/labwc/scripts/launcher" />
    </keybind>
    <keybind key="A-space">
      <action name="ShowMenu" menu="root-menu" />
    </keybind>

    <!-- 窗口管理 -->
    <keybind key="W-Tab">
      <action name="NextWindow" output="cursor" />
    </keybind>
    <keybind key="W-S-Tab">
      <action name="PreviousWindow" output="cursor" />
    </keybind>
    <keybind key="W-q">
      <action name="Close" />
    </keybind>
    <keybind key="W-f">
      <action name="ToggleFullscreen" />
    </keybind>
    <keybind key="W-m">
      <action name="ToggleMaximize" />
    </keybind>

    <!-- 工作区总览 -->
    <keybind key="W-Space">
      <action name="ToggleWorkspaceOverview" />
    </keybind>

    <!-- 编辑 (macOS 风格: Win → Ctrl) -->
    <keybind key="W-c">
      <action name="Execute" command="wtype -M Ctrl c -m Ctrl" />
    </keybind>
    <keybind key="W-v">
      <action name="Execute" command="wtype -M Ctrl v -m Ctrl" />
    </keybind>
    <keybind key="W-x">
      <action name="Execute" command="wtype -M Ctrl x -m Ctrl" />
    </keybind>
    <keybind key="W-z">
      <action name="Execute" command="wtype -M Ctrl z -m Ctrl" />
    </keybind>
    <keybind key="W-s">
      <action name="Execute" command="wtype -M Ctrl s -m Ctrl" />
    </keybind>

    <!-- 剪贴板历史 (Alt+V) -->
    <keybind key="A-v">
      <action name="Execute" command="~/.config/cliphist/cliphist-fuzzel" />
    </keybind>

    <!-- 截图 -->
    <keybind key="W-S-a">
      <action name="Execute" command="~/.config/labwc/scripts/screenshot-keybind area" />
    </keybind>

    <!-- Kazamo (语音输入法) - 请在此文件修改，勿直接改 rc.xml -->
    <keybind key="A-a">
      <action name="Execute" command="sh -c 'PATH=$HOME/.local/bin:$PATH kazamo toggle'" />
    </keybind>

    <!-- 通用: 键盘切换 -->
    <keybind key="A-k">
      <action name="ShowMenu" menu="keyboard-menu" />
    </keybind>
    <keybind key="A-S-k">
      <action name="Execute" command="~/.config/labwc/scripts/keyboard-profile next" />
    </keybind>

    <!-- 通用: 窗口切换 -->
    <keybind key="C-Tab">
      <action name="NextWindow" />
    </keybind>
    <keybind key="C-S-Tab">
      <action name="PreviousWindow" />
    </keybind>

    <!-- 通用: 工作区切换 -->
    <keybind key="A-Left">
      <action name="GoToDesktop" to="left" wrap="yes" />
    </keybind>
    <keybind key="A-Right">
      <action name="GoToDesktop" to="right" wrap="yes" />
    </keybind>
    <keybind key="A-1">
      <action name="GoToDesktop" to="1" />
    </keybind>
    <keybind key="A-2">
      <action name="GoToDesktop" to="2" />
    </keybind>
    <keybind key="A-3">
      <action name="GoToDesktop" to="3" />
    </keybind>
    <keybind key="A-4">
      <action name="GoToDesktop" to="4" />
    </keybind>
    <keybind key="A-S-1">
      <action name="SendToDesktop" to="1" follow="yes" />
    </keybind>
    <keybind key="A-S-2">
      <action name="SendToDesktop" to="2" follow="yes" />
    </keybind>
    <keybind key="A-S-3">
      <action name="SendToDesktop" to="3" follow="yes" />
    </keybind>
    <keybind key="A-S-4">
      <action name="SendToDesktop" to="4" follow="yes" />
    </keybind>

    <!-- 通用: 截图 -->
    <keybind key="Print">
      <action name="Execute" command="~/.config/labwc/scripts/screenshot-keybind full" />
    </keybind>
    <keybind key="A-Print">
      <action name="Execute" command="~/.config/labwc/scripts/screenshot-keybind full-save" />
    </keybind>
    <keybind key="S-Print">
      <action name="Execute" command="~/.config/labwc/scripts/screenshot-keybind area-save" />
    </keybind>

    <!-- 通用: 亮度 -->
    <keybind key="XF86MonBrightnessUp">
      <action name="Execute" command="~/.config/labwc/scripts/brightness-control up" />
    </keybind>
    <keybind key="XF86MonBrightnessDown">
      <action name="Execute" command="~/.config/labwc/scripts/brightness-control down" />
    </keybind>

    <!-- 通用: 音量 -->
    <keybind key="XF86AudioRaiseVolume">
      <action name="Execute" command="sh -c 'pactl set-sink-volume @DEFAULT_SINK@ +2% &amp;&amp; quickshell -p ~/.config/quickshell/labwc ipc call volume-helper triggerUpdate'" />
    </keybind>
    <keybind key="XF86AudioLowerVolume">
      <action name="Execute" command="sh -c 'pactl set-sink-volume @DEFAULT_SINK@ -2% &amp;&amp; quickshell -p ~/.config/quickshell/labwc ipc call volume-helper triggerUpdate'" />
    </keybind>
    <keybind key="XF86AudioMute">
      <action name="Execute" command="sh -c 'pactl set-sink-mute @DEFAULT_SINK@ toggle &amp;&amp; quickshell -p ~/.config/quickshell/labwc ipc call volume-helper triggerUpdate'" />
    </keybind>

  </keyboard>

  <mouse>
    <default />
    <context name="Frame">
      <mousebind button="A-Left" action="Drag">
        <action name="Move" />
      </mousebind>
    </context>
    <context name="Root">
      <mousebind button="Right" action="Press">
        <action name="ShowMenu" menu="root-menu" />
      </mousebind>
    </context>
  </mouse>

  <windowRules>
    <windowRule identifier="wofi" skipTaskbar="yes" skipWindowSwitcher="yes">
      <action name="ToggleAlwaysOnTop" />
      <action name="Raise" />
      <action name="Focus" />
    </windowRule>
    <windowRule identifier="*kitty*">
      <titlebarColor>#000000</titlebarColor>
      <titlebarTextColor>#ffffff</titlebarTextColor>
    </windowRule>
    <windowRule identifier="*alacritty*">
      <titlebarColor>#000000</titlebarColor>
      <titlebarTextColor>#ffffff</titlebarTextColor>
    </windowRule>
    <windowRule identifier="*alacrtty*">
      <titlebarColor>#000000</titlebarColor>
      <titlebarTextColor>#ffffff</titlebarTextColor>
    </windowRule>
    <windowRule identifier="*kwrite*">
      <titlebarColor>#808080</titlebarColor>
      <titlebarTextColor>#ffffff</titlebarTextColor>
    </windowRule>
    <!-- Test forced SSD on CSD apps -->
    <windowRule identifier="*code*">
      <serverDecoration>yes</serverDecoration>
      <titlebarColor>#1e1e1e</titlebarColor>
      <titlebarTextColor>#cccccc</titlebarTextColor>
    </windowRule>
    <windowRule identifier="*firefox*">
      <serverDecoration>yes</serverDecoration>
      <titlebarColor>#1e1e1e</titlebarColor>
      <titlebarTextColor>#cccccc</titlebarTextColor>
    </windowRule>
    <windowRule identifier="*chrome*">
      <serverDecoration>yes</serverDecoration>
      <titlebarColor>#1e1e1e</titlebarColor>
      <titlebarTextColor>#cccccc</titlebarTextColor>
    </windowRule>
  </windowRules>

  <hotCorner>
    <topLeft x="1" y="1">
      <action name="GoToDesktop" to="left" wrap="yes" />
    </topLeft>
    <topRight x="1" y="1">
      <action name="ToggleWorkspaceOverview" />
    </topRight>
  </hotCorner>
</labwc_config>
