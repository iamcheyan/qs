#!/bin/sh
set -eu

direction="${1:-forward}"
lock="${XDG_RUNTIME_DIR:-/tmp}/labwc-wofi-window-switcher.lock"

if window_id="$(
	xdotool search --onlyvisible --class '^wofi$' 2>/dev/null |
		tail -n 1
)" && [ -n "$window_id" ]; then
	xdotool windowactivate --sync "$window_id"
	case "$direction" in
	forward)
		exec xdotool key --clearmodifiers --window "$window_id" Tab
		;;
	back)
		exec xdotool key --clearmodifiers --window "$window_id" shift+Tab
		;;
	*)
		exit 2
		;;
	esac
fi

exec 9>"$lock"
flock -n 9 || exit 0

windows="$(wlrctl toplevel list)"
[ -n "$windows" ] || exit 0

if [ "$direction" = "back" ]; then
	windows="$(printf '%s\n' "$windows" | tac)"
fi

find_icon() {
	app_id="$1"
	icon_name=""

	for desktop_dir in \
		"${XDG_DATA_HOME:-$HOME/.local/share}/applications" \
		/usr/local/share/applications \
		/usr/share/applications; do
		[ -d "$desktop_dir" ] || continue

		desktop_file="$desktop_dir/$app_id.desktop"
		if [ ! -f "$desktop_file" ]; then
			desktop_file="$(
				grep -ilEm1 \
					"^(StartupWMClass|X-GNOME-WMClass)=${app_id}$" \
					"$desktop_dir"/*.desktop 2>/dev/null |
					head -n 1
			)"
		fi

		if [ -n "$desktop_file" ] && [ -f "$desktop_file" ]; then
			icon_name="$(
				sed -n 's/^Icon=//p' "$desktop_file" |
					head -n 1
			)"
			[ -n "$icon_name" ] && break
		fi
	done

	[ -n "$icon_name" ] || icon_name="$app_id"

	if [ -f "$icon_name" ]; then
		printf '%s\n' "$icon_name"
		return
	fi

	for icon_dir in \
		"$HOME/.local/share/icons" \
		/usr/local/share/icons \
		/usr/share/icons/Papirus \
		/usr/share/icons/hicolor \
		/usr/share/pixmaps; do
		[ -d "$icon_dir" ] || continue
		icon_path="$(
			find "$icon_dir" -type f \
				\( -iname "$icon_name.svg" \
				-o -iname "$icon_name.png" \
				-o -iname "$icon_name.xpm" \) \
				2>/dev/null |
				sort -r |
				head -n 1
		)"
		if [ -n "$icon_path" ]; then
			printf '%s\n' "$icon_path"
			return
		fi
	done
}

entries=""
while IFS= read -r window; do
	app_id="${window%%:*}"
	icon="$(find_icon "$app_id")"
	if [ -n "$icon" ]; then
		entries="${entries}img:${icon}:text:${window}
"
	else
		entries="${entries}${window}
"
	fi
done <<EOF
$windows
EOF

selection="$(
	printf '%s' "$entries" |
		env GDK_BACKEND=x11 wofi \
			--dmenu \
			--normal-window \
			--allow-images \
			--parse-search \
			--prompt "Windows" \
			--width 680 \
			--height 360 \
			--matching fuzzy \
			--insensitive \
			--define dmenu-parse_action=true
)" || exit 0

[ -n "$selection" ] || exit 0

app_id="${selection%%:*}"
title="${selection#*: }"

if [ "$title" = "$selection" ]; then
	exec wlrctl toplevel focus "app_id:$app_id"
fi

exec wlrctl toplevel focus "app_id:$app_id" "title:$title"
