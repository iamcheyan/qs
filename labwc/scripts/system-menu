#!/bin/sh
# System Power Dialog вАФ fuzzel
set -eu

ICO_POW='пАС'
ICO_EXIT='пВЛ'
ICO_MOON='пЖЖ'
ICO_SLEEP='у∞Т≤'
ICO_REPEAT='пАЮ'
ICO_REFRESH='пА°'

# Check fuzzel version for compatibility
FUZZEL_VERSION=$(fuzzel --version 2>/dev/null | sed -n 's/.*version: \([0-9]*\.[0-9]*\).*/\1/p')
FUZZEL_MAJOR=$(echo "$FUZZEL_VERSION" | cut -d. -f1)
FUZZEL_MINOR=$(echo "$FUZZEL_VERSION" | cut -d. -f2)

# Build fuzzel options based on version (supports --hide-prompt and --anchor since 1.10)
FUZZEL_BASE="fuzzel --dmenu --width 24"
if [ "$FUZZEL_MAJOR" -gt 1 ] 2>/dev/null || { [ "$FUZZEL_MAJOR" -eq 1 ] 2>/dev/null && [ "$FUZZEL_MINOR" -ge 10 ] 2>/dev/null; }; then
    FUZZEL_BASE="$FUZZEL_BASE --hide-prompt --anchor center"
fi
FUZZEL="$FUZZEL_BASE"

is_wsl() {
    [ -n "${WSL_DISTRO_NAME:-}" ] && return 0
    [ -n "${WSL_INTEROP:-}" ] && return 0
    [ -n "${WSLENV:-}" ] && return 0
    [ -r /proc/version ] && grep -qiE 'microsoft|wsl' /proc/version 2>/dev/null && return 0
    case "$(uname -r 2>/dev/null)" in *microsoft*|*WSL*|*wsl*) return 0 ;; esac
    return 1
}

confirm() {
    local label="$1"
    local answer
    answer=$(printf "No\nYes, %s" "$label" | $FUZZEL_BASE --lines 2 --prompt "  Confirm: ")
    [ "$answer" = "Yes, $label" ]
}

action="${1:-choose}"
[ "$action" != "choose" ] && action="$(echo "$action" | sed 's/./\U&/')"

can_hibernate() {
    grep -q disk /sys/power/state 2>/dev/null
}

if [ "$action" = "choose" ]; then
    if is_wsl; then
        action=$(printf "%sв†Ав†АReload labwc\n%sв†Ав†АExit labwc" "$ICO_REFRESH" "$ICO_EXIT" | $FUZZEL --lines 2)
    else
        menu_items="$(printf "%sв†Ав†АReload labwc\n%sв†Ав†АExit labwc\n%sв†Ав†АSuspend" \
            "$ICO_REFRESH" "$ICO_EXIT" "$ICO_MOON")"
        n=3
        if can_hibernate; then
            menu_items="$menu_items$(printf "\n%sв†Ав†АHibernate" "$ICO_SLEEP")"
            n=$((n + 1))
        fi
        menu_items="$menu_items$(printf "\n%sв†Ав†АReboot\n%sв†Ав†АPower Off" \
            "$ICO_REPEAT" "$ICO_POW")"
        n=$((n + 2))
        action=$(printf '%s' "$menu_items" | $FUZZEL --lines "$n")
    fi
fi

case "$action" in
    *"Reload labwc"*)  exec labwc -r ;;
    *"Exit labwc"*)    exec labwc -e ;;
    *"Suspend"*)       confirm "Suspend" && exec systemctl suspend ;;
    *"Hibernate"*)     confirm "Hibernate" && exec systemctl hibernate ;;
    *"Reboot"*)        confirm "Reboot" && exec systemctl reboot ;;
    *"Power Off"*)     confirm "Power Off" && exec systemctl poweroff ;;
    *)                 exit 0 ;;
esac
