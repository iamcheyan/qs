#!/bin/sh
# labwc autostart
# WSL detection added so native-only or host-specific daemons can be skipped
# when running as nested compositor via wsl-boot (or inside WSL distro).

is_wsl() {
    [ -n "${WSL_DISTRO_NAME:-}" ] && return 0
    [ -n "${WSL_INTEROP:-}" ] && return 0
    [ -n "${WSLENV:-}" ] && return 0
    if [ -r /proc/version ]; then
        grep -qiE 'microsoft|wsl' /proc/version 2>/dev/null && return 0
    fi
    case "$(uname -r 2>/dev/null)" in
        *microsoft*|*WSL*|*wsl*) return 0 ;;
    esac
    return 1
}

# Wallpaper, bar, notifications, clipboard history: useful for both native and
# nested labwc (the inner session still wants its own UI).
"$HOME/.config/TWM/set-wallpaper" wayland >/dev/null 2>&1 &
mako >/dev/null 2>&1 &
fcitx5 &
"$HOME/.config/labwc/scripts/waybar" \
	>"${XDG_RUNTIME_DIR:-/tmp}/waybar-labwc.log" 2>&1 &
command -v cliphist >/dev/null && {
	wl-paste --type text --watch cliphist store >/dev/null 2>&1 &
	wl-paste --type image --watch cliphist store >/dev/null 2>&1 &
}

# Input method (fcitx5).
# In WSL/WSLg the host Windows input method or WSLg often handles this.
# Force start inside WSL by setting LABWC_START_FCITX=1 before launching labwc.
if ! is_wsl || [ "${LABWC_START_FCITX:-0}" = "1" ]; then
    fcitx5 >/dev/null 2>&1 &
fi

# HiDPI / output scaling — auto-detect per output resolution
# 4K (>=3840) → scale 2, 1440p/retina (>=2560) → scale 1.5, 1080p and below → scale 1
# Override per-output via env: LABWC_SCALE_HDMI_A_1=1.25 (output name, replace - with _)
if command -v wlr-randr >/dev/null 2>&1; then
    _cur_out=""
    wlr-randr 2>/dev/null | while IFS= read -r _l; do
        # output name line: starts with letter, contains dash + digit (e.g. HDMI-A-1)
        if printf '%s' "$_l" | grep -qE '^[A-Za-z].*-[0-9]'; then
            _cur_out=$(printf '%s' "$_l" | cut -d' ' -f1)
        elif [ -n "$_cur_out" ] && printf '%s' "$_l" | grep -q 'current'; then
            _w=$(printf '%s' "$_l" | grep -oE '[0-9]+x[0-9]+' | head -1 | cut -dx -f1)
            if [ -n "$_w" ]; then
                _var="LABWC_SCALE_$(echo "$_cur_out" | tr '-' '_')"
                _s="${!_var:-}"
                [ -z "$_s" ] && [ "$_w" -ge 3840 ] && _s=2
                [ -z "$_s" ] && [ "$_w" -ge 2560 ] && _s=1.5
                [ -z "$_s" ] && _s=1
                [ "$_s" != "1" ] && wlr-randr --output "$_cur_out" --scale "$_s" 2>/dev/null
            fi
            _cur_out=""
        fi
    done
fi

# Apply GTK theme via gsettings for better client consistency (if schema exists)
if command -v gsettings >/dev/null 2>&1; then
    gsettings set org.gnome.desktop.interface gtk-theme 'BL-Lithium-dark' 2>/dev/null || true
    gsettings set org.gnome.desktop.interface icon-theme 'Adwaita' 2>/dev/null || true
fi
